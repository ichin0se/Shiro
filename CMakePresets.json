{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 24,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "vs2022-x64",
      "displayName": "VS2022 x64",
      "generator": "Visual Studio 17 2022",
      "binaryDir": "${sourceDir}/build-vs2022",
      "architecture": {
        "value": "x64",
        "strategy": "external"
      },
      "cacheVariables": {
        "CMAKE_INSTALL_PREFIX": "${sourceDir}/out/install/vs2022",
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/external/vcpkg/scripts/buildsystems/vcpkg.cmake"
      }
    },
    {
      "name": "linux-houdini20.5",
      "displayName": "AlmaLinux 9 + Houdini 20.5.410",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build-linux-houdini20.5",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "CMAKE_INSTALL_PREFIX": "${sourceDir}/out/install/houdini20.5",
        "SHIRO_HOUDINI_ROOT": "/opt/hfs20.5.410"
      }
    },
    {
      "name": "linux-houdini20.5-cuda",
      "displayName": "AlmaLinux 9 + Houdini 20.5.410 + CUDA/OptiX",
      "inherits": "linux-houdini20.5",
      "binaryDir": "${sourceDir}/build-linux-houdini20.5-cuda",
      "cacheVariables": {
        "SHIRO_CUDA_ROOT": "/usr/local/cuda",
        "SHIRO_OPTIX_ROOT": "${sourceDir}/external/optix-sdk-9.0.0",
        "SHIRO_REQUIRE_CUDA": "ON",
        "SHIRO_REQUIRE_OPTIX": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "vs2022-debug",
      "displayName": "VS2022 Debug",
      "configurePreset": "vs2022-x64",
      "configuration": "Debug"
    },
    {
      "name": "vs2022-release",
      "displayName": "VS2022 Release",
      "configurePreset": "vs2022-x64",
      "configuration": "Release"
    },
    {
      "name": "linux-houdini20.5",
      "displayName": "AlmaLinux 9 + Houdini 20.5.410",
      "configurePreset": "linux-houdini20.5"
    },
    {
      "name": "linux-houdini20.5-cuda",
      "displayName": "AlmaLinux 9 + Houdini 20.5.410 + CUDA/OptiX",
      "configurePreset": "linux-houdini20.5-cuda"
    }
  ]
}
